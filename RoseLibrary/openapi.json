{
  "openapi": "3.1.0",
  "info": {
    "title": "RoseLibrary",
    "version": "0.1.0"
  },
  "paths": {
    "/check-file": {
      "post": {
        "summary": "Check File",
        "operationId": "check_file_check_file_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "items": {
                  "$ref": "#/components/schemas/FileCheckRequest"
                },
                "type": "array",
                "title": "Files"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/FileCheckResponse"
                  },
                  "type": "array",
                  "title": "Response Check File Check File Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/update-file": {
      "post": {
        "summary": "Update File",
        "operationId": "update_file_update_file_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FileUpdateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileUpdateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/status": {
      "get": {
        "summary": "Status",
        "operationId": "status_status_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/search": {
      "post": {
        "summary": "Search",
        "operationId": "search_search_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/SearchResult"
                  },
                  "type": "array",
                  "title": "Response Search Search Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/findReferences": {
      "post": {
        "summary": "Find References",
        "operationId": "find_references_findReferences_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindReferencesRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ReferenceResult"
                  },
                  "type": "array",
                  "title": "Response Find References Findreferences Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "Health",
        "operationId": "health__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BrokenReference": {
        "properties": {
          "target_symbol_name": {
            "type": "string",
            "title": "Target Symbol Name"
          },
          "affected_files": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Affected Files"
          }
        },
        "type": "object",
        "required": [
          "target_symbol_name",
          "affected_files"
        ],
        "title": "BrokenReference"
      },
      "FileCheckRequest": {
        "properties": {
          "path": {
            "type": "string",
            "title": "Path"
          },
          "hash": {
            "type": "string",
            "title": "Hash"
          }
        },
        "type": "object",
        "required": [
          "path",
          "hash"
        ],
        "title": "FileCheckRequest"
      },
      "FileCheckResponse": {
        "properties": {
          "path": {
            "type": "string",
            "title": "Path"
          },
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "path",
          "status"
        ],
        "title": "FileCheckResponse"
      },
      "FileUpdateRequest": {
        "properties": {
          "path": {
            "type": "string",
            "title": "Path"
          },
          "content": {
            "type": "string",
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "path",
          "content"
        ],
        "title": "FileUpdateRequest"
      },
      "FileUpdateResponse": {
        "properties": {
          "symbols_indexed": {
            "type": "integer",
            "title": "Symbols Indexed"
          },
          "broken_references": {
            "items": {
              "$ref": "#/components/schemas/BrokenReference"
            },
            "type": "array",
            "title": "Broken References"
          }
        },
        "type": "object",
        "required": [
          "symbols_indexed",
          "broken_references"
        ],
        "title": "FileUpdateResponse"
      },
      "FindReferencesRequest": {
        "properties": {
          "file_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "File Path"
          },
          "symbol_name": {
            "type": "string",
            "title": "Symbol Name"
          },
          "direction": {
            "type": "string",
            "pattern": "^(inbound|outbound|both)$",
            "title": "Direction",
            "default": "both"
          }
        },
        "type": "object",
        "required": [
          "symbol_name"
        ],
        "title": "FindReferencesRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ReferenceResult": {
        "properties": {
          "source_file": {
            "type": "string",
            "title": "Source File"
          },
          "source_symbol": {
            "type": "string",
            "title": "Source Symbol"
          },
          "target_symbol_name": {
            "type": "string",
            "title": "Target Symbol Name"
          },
          "target_file_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Target File Path"
          },
          "type": {
            "type": "string",
            "title": "Type"
          },
          "line_number": {
            "type": "integer",
            "title": "Line Number"
          }
        },
        "type": "object",
        "required": [
          "source_file",
          "source_symbol",
          "target_symbol_name",
          "target_file_path",
          "type",
          "line_number"
        ],
        "title": "ReferenceResult"
      },
      "SearchRequest": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query"
          },
          "limit": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Limit",
            "default": 10
          },
          "metadata_weight": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Metadata Weight",
            "default": 0.5
          },
          "code_weight": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Code Weight",
            "default": 0.5
          }
        },
        "type": "object",
        "required": [
          "query"
        ],
        "title": "SearchRequest"
      },
      "SearchResult": {
        "properties": {
          "symbol_name": {
            "type": "string",
            "title": "Symbol Name"
          },
          "qualified_name": {
            "type": "string",
            "title": "Qualified Name"
          },
          "file_path": {
            "type": "string",
            "title": "File Path"
          },
          "type": {
            "type": "string",
            "title": "Type"
          },
          "line_start": {
            "type": "integer",
            "title": "Line Start"
          },
          "line_end": {
            "type": "integer",
            "title": "Line End"
          },
          "source_code": {
            "type": "string",
            "title": "Source Code"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "docstring": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Docstring"
          }
        },
        "type": "object",
        "required": [
          "symbol_name",
          "qualified_name",
          "file_path",
          "type",
          "line_start",
          "line_end",
          "source_code",
          "score"
        ],
        "title": "SearchResult"
      },
      "StatusResponse": {
        "properties": {
          "files_indexed": {
            "type": "integer",
            "title": "Files Indexed"
          },
          "symbols_indexed": {
            "type": "integer",
            "title": "Symbols Indexed"
          },
          "references_total": {
            "type": "integer",
            "title": "References Total"
          },
          "unresolved_count": {
            "type": "integer",
            "title": "Unresolved Count"
          },
          "unresolved_references": {
            "items": {
              "$ref": "#/components/schemas/UnresolvedRef"
            },
            "type": "array",
            "title": "Unresolved References"
          }
        },
        "type": "object",
        "required": [
          "files_indexed",
          "symbols_indexed",
          "references_total",
          "unresolved_count",
          "unresolved_references"
        ],
        "title": "StatusResponse"
      },
      "UnresolvedRef": {
        "properties": {
          "source_file": {
            "type": "string",
            "title": "Source File"
          },
          "source_symbol": {
            "type": "string",
            "title": "Source Symbol"
          },
          "target_symbol_name": {
            "type": "string",
            "title": "Target Symbol Name"
          },
          "type": {
            "type": "string",
            "title": "Type"
          },
          "line_number": {
            "type": "integer",
            "title": "Line Number"
          }
        },
        "type": "object",
        "required": [
          "source_file",
          "source_symbol",
          "target_symbol_name",
          "type",
          "line_number"
        ],
        "title": "UnresolvedRef"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
