{
  "name": "projectrose",
  "version": "0.1.0",
  "description": "ProjectRose - A code editor IDE with AI chat integration",
  "author": "RoseAgent",
  "repository": {
    "type": "git",
    "url": "https://github.com/RoseAgent/ProjectRose.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "typecheck:main": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:preload": "tsc --noEmit -p tsconfig.preload.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.renderer.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:preload && npm run typecheck:renderer",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "coverage": "vitest run --coverage",
    "dist": "electron-vite build && electron-builder"
  },
  "build": {
    "appId": "com.projectrose.app",
    "productName": "ProjectRose",
    "icon": "build/icon",
    "protocols": [
      {
        "name": "ProjectRose",
        "schemes": [
          "projectrose"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "../rosespeech-dist/rosespeech",
        "to": "rosespeech",
        "filter": [
          "**/*"
        ]
      }
    ],
    "npmRebuild": false,
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png"
    },
    "mac": {
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.96",
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "ai": "^6.0.168",
    "ai-sdk-ollama": "^3.8.3",
    "clsx": "^2.1.1",
    "discord.js": "^14.26.3",
    "imapflow": "^1.3.2",
    "mailparser": "^3.9.8",
    "monaco-editor": "^0.52.2",
    "pyright": "^1.1.409",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "typescript-language-server": "^4.4.1",
    "zod": "^3.25.76",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@projectrose/rose-discord": "*",
    "@projectrose/rose-docker": "*",
    "@projectrose/rose-email": "*",
    "@projectrose/rose-git": "*",
    "@projectrose/rose-listen": "*",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/mailparser": "^3.4.6",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "node-pty": "^1.0.0",
    "to-ico": "^1.1.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^4.1.5"
  }
}
